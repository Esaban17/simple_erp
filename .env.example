# =============================================================
# simple_erp — Variables de entorno requeridas
# =============================================================
# Copia este archivo a .env y rellena los valores:
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# NUNCA confirmes el archivo .env al repositorio.
# =============================================================


# -------------------------------------------------------------
# Django — Configuración principal
# -------------------------------------------------------------

# Clave secreta de Django. Debe ser larga, aleatoria y única.
# Genera una con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=g2i4_DAY2HluLS3^_@@a2g*#tT0!xVp%rig(aUj_f8hPF2U@6&

# Modo debug. Usa True solo en desarrollo local. En producción: False
DJANGO_DEBUG=True

# Hosts permitidos, separados por coma.
# Desarrollo local: localhost,127.0.0.1
# Producción: tu-dominio.com,www.tu-dominio.com
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"


# -------------------------------------------------------------
# Base de datos — PostgreSQL
# -------------------------------------------------------------

# Nombre de la base de datos (debe crearse antes de correr migrate)
DB_NAME=tienda

# Usuario de PostgreSQL (por defecto: postgres)
DB_USER=postgres

# Contraseña del usuario de PostgreSQL
DB_PASSWORD="P@ssw0rdDBERP2026"

# Host de la base de datos
# - Desarrollo local: 127.0.0.1
# - Dentro de Docker Compose: db  (nombre del servicio)
DB_HOST=127.0.0.1

# Puerto de PostgreSQL (por defecto: 5432)
DB_PORT=5432


# -------------------------------------------------------------
# Superusuario por defecto — solo para desarrollo
# -------------------------------------------------------------
# Creado automáticamente al correr: docker compose up  o  make setup
# Cambia estos valores antes de cualquier despliegue real.

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com


# -------------------------------------------------------------
# Email SMTP — Para envío de facturas y albaranes en PDF/Excel
# -------------------------------------------------------------
# Si no configuras estas variables, la generación de Excel funcionará
# pero el envío de correo fallará. El sistema no está preparado para
# fallos de SMTP — un error aquí producirá un error 500 en la UI.

# Servidor SMTP de tu proveedor de correo
# Ejemplos: smtp.gmail.com | smtp.office365.com | mail.tudominio.com
SMTP_SERVER=smtp.tuservidor.com

# Puerto SMTP. 587 = TLS (recomendado). 465 = SSL. 25 = sin cifrado
SMTP_PORT=587

# Credenciales de autenticación SMTP
SMTP_USERNAME=tu-email@ejemplo.com
SMTP_PASSWORD=tu-contrasena-smtp

# Dirección que aparece en el campo "De:" del correo enviado
EMAIL_SENDER=tu-email@ejemplo.com

# Dirección que recibirá las facturas/albaranes generados
EMAIL_RECEIVER=destinatario@ejemplo.com


# -------------------------------------------------------------
# Rutas de archivos — Plantillas y directorios de salida
# -------------------------------------------------------------
# Rutas relativas al directorio raíz del proyecto.
# En Docker Compose estas rutas ya están configuradas como volúmenes
# y no necesitan cambiarse.

# Ruta a la plantilla Excel de facturas (incluida en el repositorio)
PLANTILLA_FACTURAS=./23AKP08PL_PLANTILLA.xlsx

# Ruta a la plantilla Excel de albaranes (incluida en el repositorio)
PLANTILLA_ALBARANES=./23AKP08_PLANTILLA.xlsx

# Directorio donde se guardan las facturas Excel generadas
# Se crea automáticamente con: make dirs  o  docker compose up
FACTURAS_DIR=./facturas

# Directorio donde se guardan los albaranes Excel generados
ALBARANES_DIR=./albaranes
